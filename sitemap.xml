---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- assign pages = site.html_pages | where_exp: "p", "p.sitemap != false" -%}
{%- for p in pages -%}
{%- unless p.url == "/404.html" %}
  <url>
    <loc>{{ p.url | absolute_url | xml_escape }}</loc>
    {%- if p.last_modified_at %}
    <lastmod>{{ p.last_modified_at | date_to_xmlschema }}</lastmod>
    {%- endif %}
  </url>
{%- endunless -%}
{%- endfor %}
{%- assign stories = site.stories | sort: "date" -%}
{%- for s in stories -%}
{%- if s.date <= site.time and s.sitemap != false %}
  <url>
    <loc>{{ s.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ s.date | date_to_xmlschema }}</lastmod>
  </url>
{%- endif -%}
{%- endfor %}
</urlset>
